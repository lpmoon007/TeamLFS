# The Signal — environment variables (handoff §0)
# Copy to `.env.local` (Next.js) / set in Vercel + Supabase. Do NOT commit real values.

# --- Supabase (server) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Used by Edge Functions / server actions
# to resolve magic-link tokens, read the seat bundle, and write the capture log
# (bypasses RLS).
SUPABASE_SERVICE_ROLE=

# --- Supabase (browser / Next.js client) ---
# The participant app's Realtime channel uses the anon client in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AI / Voice (server-side only — keys never reach the browser) ---
ANTHROPIC_API_KEY=
ELEVENLABS_KEY=
# Optional overrides:
#   VOICE_MODEL       NPC in-character reply model (default: claude-opus-4-8)
#   SOLO_MODEL        solo referee/advisor model (default: claude-haiku-4-5)
#   SCORER_MODEL      behavioral AI coder, runs once per session (default: claude-sonnet-5)
#   ELEVENLABS_MODEL  TTS model (default: eleven_turbo_v2_5)
# VOICE_MODEL=claude-opus-4-8
# SOLO_MODEL=claude-haiku-4-5
# SCORER_MODEL=claude-sonnet-5
# ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- Facilitator / automation (server-only) ---
# Shared secret guarding the facilitator endpoints (/api/facilitator/*) — console +
# manual inject/Director triggers.
FACILITATOR_SECRET=
# Secret Vercel Cron sends as the bearer on scheduled Director ticks
# (/api/cron/director). Set the same value in the Vercel project's Cron settings.
# If unset, the cron route falls back to accepting FACILITATOR_SECRET.
CRON_SECRET=
